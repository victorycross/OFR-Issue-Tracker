# ═══════════════════════════════════════════════════════════
# One Firm Risk Tracker — Environment Variables
# ═══════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values.
# These variables are exposed to the browser (VITE_ prefix).
#
# To get these values:
#   1. Go to https://entra.microsoft.com
#   2. App registrations → your app
#   3. Copy the Application (client) ID and Directory (tenant) ID
#
# ═══════════════════════════════════════════════════════════

# Microsoft Entra ID (Azure AD) App Registration
VITE_CLIENT_ID=YOUR_CLIENT_ID
VITE_TENANT_ID=YOUR_TENANT_ID

# SharePoint Site Configuration
VITE_SP_HOSTNAME=yourcompany.sharepoint.com
VITE_SP_SITE_PATH=/sites/ofr-risk-tracker
